# ── Never commit (huge / machine-specific / secrets) ──
venv/
.venv/
__pycache__/
*.pyc
.env
*.log
logs/

# LLM model weights — Ollama downloads these on the server (never commit ~1GB)
*.gguf
*.bin
*.safetensors

# ── User data (contains hashed passwords + trades — never commit) ──
data/users.db

# ── Runtime state (regenerated on the server; do NOT commit) ──
data/aos/
data/agents/
data/api_cache/
data/intraday/
data/option_chain/
data/paper/
data/feature_store/
data/feature_store.db
data/cache/
data/ml_performance.db
outputs/

# ── Old model versions (only latest.pkl + latest_meta.json are committed) ──
models/ml_v2/v2_*.pkl
models/ml_v2/v2_*_meta.json
models/ml_v2/v3_2*.pkl
models/ml_v2/v3_2*_meta.json
models/intraday/intraday_*.pkl
models/intraday/index_options_*.pkl

# ── DO commit (needed to run): code + price history + fundamentals + models ──
# data/historical/*.csv         (10-yr price + index CSVs)  — kept
# data/*_daily.csv              (index dailies)             — kept
# data/historical/*.json        (fundamentals)              — kept
# models/*.pkl, models/*.json, models/registry/             — kept
# everything under api/ aos/ agents/ models/ pipelines/ infra/ training/ — kept
